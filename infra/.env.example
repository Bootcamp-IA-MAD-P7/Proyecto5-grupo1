# Copiar a infra/.env para desarrollo local (no commitear .env)
# cp infra/.env.example infra/.env

# API
PORT=8000

# Supabase (versiones APK + futura telemetría/feedback)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Modelo activo en inferencia (nivel Medio+)
MODEL_PATH=ml/model.pkl
MODEL_VERSION=baseline-v1

# Base de datos local (docker-compose)
POSTGRES_USER=fallsentinel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fallsentinel
DATABASE_URL=postgresql://fallsentinel:changeme@db:5432/fallsentinel

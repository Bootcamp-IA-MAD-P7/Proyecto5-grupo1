# Copiar a .env.qa en la raíz — NO commitear .env.qa
# cp .env.qa.example .env.qa
#
# Apunta el frontend Flutter al stack QA desplegado en EC2 (34.235.130.33).
# Flutter habla con el backend Java — NO con inference directamente.


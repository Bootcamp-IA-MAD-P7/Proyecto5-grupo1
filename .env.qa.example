# Copiar a .env.qa en la raíz — NO commitear .env.qa
# cp .env.qa.example .env.qa
#
# Apunta el frontend Flutter al stack QA desplegado en EC2 (34.235.130.33).
# Flutter habla con el backend Java — NO con inference directamente.

# ── Java API (pública) ─────────────────────────────────────────────
QA_API_HOST=34.235.130.33
QA_API_PORT=8005
API_BASE_URL=http://34.235.130.33:8005

# ── Servicios en EC2 (solo admin/debug) ──────────────────────────
# Postgres NO está expuesto en host (evita conflicto con 5435 legacy).
# Acceso: ssh EC2 → docker exec -it sentilife-db psql -U fallsentinel -d fallsentinel

QA_GRAFANA_URL=http://34.235.130.33:3006


# Copiar a .env.qa en la raíz — NO commitear .env.qa
# cp .env.qa.example .env.qa
#
# Apunta el frontend Flutter al stack QA desplegado en EC2.
# Credenciales DB: ver .env.example (no commitear contraseñas).

# API QA (EC2)
QA_API_HOST=<EC2_HOST>
QA_API_PORT=8005
API_BASE_URL=http://<EC2_HOST>:8005

# Postgres QA — solo debug manual (psql, DBeaver); la app Flutter no lo usa
QA_POSTGRES_HOST=<EC2_HOST>
QA_POSTGRES_PORT=5435
# QA_DATABASE_URL=postgresql://fallsentinel:<POSTGRES_PASSWORD>@<EC2_HOST>:5435/fallsentinel

# Flutter — dispositivo adb (opcional)
# DEVICE=OJLNRO8PNFLNNBFA

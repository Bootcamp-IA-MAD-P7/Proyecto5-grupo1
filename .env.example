# Copy to .env at root — NEVER commit .env
# cp .env.example .env

# ── API ports ─────────────────────────────────────────────────
PORT=8000
JAVA_PORT=8080
GRAFANA_PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=fallsentinel
POSTGRES_PASSWORD=fallsentinel123
POSTGRES_DB=fallsentinel
DATABASE_URL=postgresql://fallsentinel:fallsentinel123@db:5432/fallsentinel

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── JWT (Java backend) ────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production-min-32-chars-long!!

# ── ML / Inference ────────────────────────────────────────────
MODEL_PATH=ml/model.pkl
MODEL_VERSION=baseline-v1
INFERENCE_URL=http://api:8000

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Firebase (push notifications) ─────────────────────────────
# Path to Firebase service account JSON (relative to backend-java/)
# FIREBASE_SERVICE_ACCOUNT=firebase-service-account.json

# ── QA / frontend against EC2 ─────────────────────────────────
# cp .env.qa.example .env.qa && make flutter-qa

# ── Flutter local — LAN IP of your PC (same WiFi as phone) ────
# API_HOST=192.168.1.100
# DEVICE=OJLNRO8PNFLNNBFA

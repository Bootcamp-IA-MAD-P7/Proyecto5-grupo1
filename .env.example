# Copiar a .env en la raíz — NO commitear .env
# cp .env.example .env

# API
PORT=8000
JAVA_PORT=8080

# PostgreSQL (contenedor fallsentinel-db, red interna Docker)
POSTGRES_USER=fallsentinel
POSTGRES_PASSWORD=fallsentinel123
POSTGRES_DB=fallsentinel
DATABASE_URL=postgresql://fallsentinel:fallsentinel123@db:5432/fallsentinel

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT (backend Java)
JWT_SECRET=dev-secret-change-in-production-min-32-chars-long!!

# ML
MODEL_PATH=ml/model.pkl
MODEL_VERSION=baseline-v1

# Inferencia (backend Java → FastAPI)
INFERENCE_URL=http://api:8000

# QA / frontend contra EC2 → cp .env.qa.example .env.qa && make flutter-qa

# Flutter local — IP LAN de tu PC (misma WiFi que el móvil)
# API_HOST=192.168.1.100
# DEVICE=OJLNRO8PNFLNNBFA

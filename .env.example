# SentiLife — variables de entorno
# cp .env.example .env && editar con valores reales
# NUNCA commitear .env

# ── Puertos DEV (docker-compose.yml) ─────────────────────────────
PORT=8000               # FastAPI inference
JAVA_PORT=8080          # Java backend (contenedor)
GRAFANA_PORT=3000       # Grafana (contenedor)
POSTGRES_HOST_PORT=5433  # Postgres (5432 suele estar ocupado por postgres local)
RABBITMQ_AMQP_PORT=5673  # AMQP (5672 suele estar ocupado por rabbitmq local)
RABBITMQ_MGMT_PORT=15673 # RabbitMQ management UI

# ── Puertos PROD — host EC2 (docker-compose.prod.yml) ────────────
# IP EC2: 100.52.221.179
# Java API  → http://100.52.221.179:8005  (regla SG "FA: SentiLife API Java")
# DB debug  → 100.52.221.179:5435         (regla SG "FA: SentiLife DB")
# Grafana   → http://100.52.221.179:3006  (regla SG "Grafana dashboard")
JAVA_HOST_PORT=8005
POSTGRES_HOST_PORT=5435
GRAFANA_HOST_PORT=3006

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=fallsentinel
POSTGRES_PASSWORD=fallsentinel123
POSTGRES_DB=fallsentinel

# ── RabbitMQ ──────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── JWT (backend Java — CRÍTICO) ──────────────────────────────────
# En producción: cadena aleatoria >= 64 chars
# Ejemplo: openssl rand -base64 64
JWT_SECRET=dev-secret-change-in-production-min-32-chars-long!!

# ── ML / Inference ────────────────────────────────────────────────
MODEL_PATH=ml/models/model.pkl
MODEL_VERSION=baseline-v1
INFERENCE_URL=http://api:8000

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Firebase — push FCM (proyecto: proyectoflutter-8a229) ───────────────────
# Guía completa: docs/firebase-setup.md
#
# 1) Carpeta secrets/ (gitignored) con:
#    secrets/google-services.json
#    secrets/*-firebase-adminsdk-*.json   (cuenta de servicio)
#
# 2) Activar rutas en .env:
GOOGLE_SERVICES_JSON_PATH=./secrets/google-services.json
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/sentilife-a7767-firebase-adminsdk-fbsvc-6015549a37.json
#
# 3) Identificadores públicos — app SentiLife (com.sentilife.app):
FIREBASE_PROJECT_ID=proyectoflutter-8a229
FIREBASE_APP_ID=1:551135695634:android:151b8a23dbb4e7aaf9d9cb
FIREBASE_MESSAGING_SENDER_ID=551135695634
# FIREBASE_API_KEY=<copiar de google-services.json — no commitear en .env.example>
#
# En CI/EC2: secrets GitHub GOOGLE_SERVICES_JSON y FIREBASE_SERVICE_ACCOUNT

# ── Docker Hub (para CI/CD) ───────────────────────────────────────
# DOCKER_USERNAME=tu-usuario
# DOCKER_PASSWORD=tu-token

# ── Flutter local — IP LAN de tu PC (misma WiFi que el móvil) ────
# API_HOST=192.168.1.100
# DEVICE=OJLNRO8PNFLNNBFA

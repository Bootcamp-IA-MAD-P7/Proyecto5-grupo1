{
  "schemaVersion": "1.0.0",
  "source": "SL-14 window contract, aligned with SDD ADR-05 and spec section 6.3/6.8",
  "window": {
    "durationMs": 2500,
    "sampleRateHz": 50,
    "overlapRatio": 0.5,
    "hopMs": 1250,
    "samplesPerSignal": 125
  },
  "preprocessing": {
    "sourceRateHz": 200,
    "resampleMethod": "linear_interpolation_to_50hz",
    "accelerationUnit": "m/s^2",
    "gyroscopeUnit": "deg/s",
    "gravityHandling": "align_to_sisfall_reference_before_features",
    "missingSamples": "reject_window_if_any_required_signal_has_less_than_125_samples",
    "extraSamples": "trim_or_resample_to_exactly_125_samples_per_required_signal",
    "normalization": "model_pipeline_only; payloads stay in physical units"
  },
  "signals": {
    "required": [
      {
        "name": "accX",
        "unit": "m/s^2"
      },
      {
        "name": "accY",
        "unit": "m/s^2"
      },
      {
        "name": "accZ",
        "unit": "m/s^2"
      },
      {
        "name": "gyroX",
        "unit": "deg/s"
      },
      {
        "name": "gyroY",
        "unit": "deg/s"
      },
      {
        "name": "gyroZ",
        "unit": "deg/s"
      }
    ],
    "optionalContext": [
      {
        "name": "heartRate",
        "unit": "bpm"
      },
      {
        "name": "roomTemp",
        "unit": "celsius"
      },
      {
        "name": "roomLight",
        "unit": "lux"
      }
    ]
  },
  "api": {
    "telemetryEndpoint": "/api/v1/telemetry/windows",
    "inferenceEndpoint": "/predict",
    "timestampFormat": "ISO-8601 UTC",
    "windowEndRule": "windowEnd must equal windowStart + 2500ms",
    "samplesObjectKeys": [
      "accX",
      "accY",
      "accZ",
      "gyroX",
      "gyroY",
      "gyroZ"
    ]
  },
  "validation": {
    "requiredSampleCount": 125,
    "requiredSampleRateHz": 50,
    "allowedSampleRateToleranceHz": 0,
    "rejectNaNOrInfinite": true,
    "rejectMissingRequiredSignals": true,
    "contextRequired": false
  },
  "compatibility": {
    "training": "ML feature generation must use the same duration, sample rate, overlap and signal keys.",
    "inference": "FastAPI must receive the same sample arrays and sampleRateHz used by training.",
    "flutter": "Flutter must build sliding windows with the same duration, sample rate, overlap and signal keys."
  }
}
